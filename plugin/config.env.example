# Herald Plugin Configuration
#
# Copy this file to config.env and edit as needed.
# Environment variables set before hook execution take precedence.

# Remote daemon address (host:port)
# Set this to connect to a Herald daemon running on another machine.
# When unset, hooks connect via Unix socket on localhost.
# Example: HERALD_DAEMON_ADDR=192.168.1.100:7272
#HERALD_DAEMON_ADDR=
